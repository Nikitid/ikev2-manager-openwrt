{
	// Hide regenerable build outputs and large artifacts from the explorer.
	// Nothing is deleted — flip to false to see them again.
	"files.exclude": {
		"**/.DS_Store": true,
		"build": true,
		"dist": true,
		"firmware": true
	},
	// Keep search and the file watcher off the heavy/transient trees.
	"search.exclude": {
		"build": true,
		"dist": true,
		"firmware": true,
		"backups": true
	},
	"files.watcherExclude": {
		"**/build/**": true,
		"**/backups/**": true,
		"**/firmware/**": true,
		"**/dist/**": true
	},
	"files.insertFinalNewline": true,
	"files.trimTrailingWhitespace": true,
	"[markdown]": {
		"files.trimTrailingWhitespace": false
	},
	// Shell + LuCI JS + UCI/JSON in this repo are tab-indented.
	"[shellscript]": {
		"editor.insertSpaces": false,
		"editor.tabSize": 4
	},
	"[javascript]": {
		"editor.insertSpaces": false,
		"editor.tabSize": 4
	},
	"[python]": {
		"editor.insertSpaces": true,
		"editor.tabSize": 4
	},
	// -x = follow `source`d includes (e.g. pbr.user.ikev2out).
	"shellcheck.customArgs": [ "-x" ],
	"shellformat.flag": "-i 0"
}
