# Single source of truth for package identity used by the canonical build
# (scripts/build-ipk.sh -> scripts/stage-package.sh -> scripts/pack-ipk.py).
#
# The OpenWrt SDK Makefile keeps its own PKG_VERSION/PKG_RELEASE literals
# because OpenWrt evaluates package Makefiles with an unreliable relative
# include path; scripts/check-version-sync.sh fails the build if the Makefile
# literals drift from these values. Public releases use PKG_VERSION directly;
# PKG_RELEASE is intentionally empty unless a future package-only rebuild is
# needed. This file is sourced as POSIX sh, so use plain VAR=value with no
# spaces around '='.
PKG_NAME=luci-app-ikev2-manager
PKG_VERSION=1.0.10
PKG_RELEASE=
PKG_ARCH=all
