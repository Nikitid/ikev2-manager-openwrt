config globals 'globals'
	option schema_version '1'
	option configured '0'
	option wan_interface 'wan'
	option wan_zone 'wan'
	list source_interface 'lan'
	list source_zone 'lan'
	option dns_enforce '0'
	option block_dot '0'
	option source_include_vpn '1'

config server 'server'
	option enabled '0'
	option identity ''
	option pool4 '10.20.30.10-10.20.30.100'
	option gateway4 '10.20.30.1/24'
	option dns4 '10.20.30.1'
	option cert_source '/etc/ssl/acme'
	option cert_file ''
	option key_file ''
	option dpd '30'
	option ike_rekey '14400'
	option child_rekey '3600'
	option mtu '1400'
	option mobike '1'
	option fragmentation '1'
	option local_ts '0.0.0.0/0'
	option allow_internet '1'
	option allow_lan '1'
	option allow_router '0'
	option router_ports ''
	list lan_zone 'lan'
	option firewall_zone 'ikev2in'
	option outbound_zone 'ikev2out'
	option custom_config '0'

config client 'client'
	option enabled '0'
	option remote_address ''
	option remote_id ''
	option username ''
	option dpd '30'
	option mtu '1400'
	option custom_config '0'

config dns 'dns'
	option managed '0'
	option protocol 'doh'
	option provider 'cloudflare'
	option upstream 'https://dns.cloudflare.com/dns-query'
	option bootstrap '1.1.1.1:53 1.0.0.1:53'
	option fallback ''
	option timeout '10s'

config domains 'domains'
	option engine 'nftset'
	option fakeip_ttl '60'
	option cache_path '/etc/ikev2-manager/domain-router-cache.db'
