#!/bin/sh /etc/rc.common

START=91
STOP=3
USE_PROCD=1

start_service() {
	[ "$(uci -q get ikev2-manager.domains.engine)" = fakeip ] || return 0
	if ! /usr/libexec/ikev2-domain-router prepare; then
		/usr/libexec/ikev2-domain-router fallback
		return 1
	fi

	procd_open_instance
	procd_set_param command /usr/bin/sing-box run \
		-c /etc/ikev2-manager/domain-router.json \
		-D /etc/ikev2-manager/domain-router
	procd_set_param user root
	procd_set_param file /etc/ikev2-manager/domain-router.json
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

stop_service() {
	[ "$(uci -q get ikev2-manager.domains.engine)" = fakeip ] ||
		/usr/libexec/ikev2-domain-router nft-stop
}
