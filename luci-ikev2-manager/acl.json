{
	"luci-app-ikev2-manager": {
		"description": "Manage and monitor the router IKEv2 system",
		"read": {
			"file": {
				"/etc/pbr-ikev2-domains.txt": [ "read" ],
				"/etc/pbr-ikev2-domains.manual.txt": [ "read" ],
				"/etc/pbr-ikev2-addresses.manual.txt": [ "read" ],
				"/etc/pbr-ikev2-community-selected.txt": [ "read" ],
				"/tmp/ikev2-domains-community.status": [ "read" ],
				"/tmp/ikev2-manager-deps.status": [ "read" ],
				"/usr/libexec/ikev2-devices networks": [ "exec" ],
				"/usr/libexec/ikev2-devices dump": [ "exec" ],
				"/usr/libexec/ikev2-domains-community catalog": [ "exec" ],
				"/usr/libexec/ikev2-domains-community ip-services": [ "exec" ],
				"/usr/libexec/ikev2-domains-community status *": [ "exec" ],
				"/usr/libexec/ikev2-domain-router status": [ "exec" ],
				"/usr/libexec/ikev2-manager users-show": [ "exec" ],
				"/usr/libexec/ikev2-manager server-get": [ "exec" ],
				"/usr/libexec/ikev2-manager server-access-get": [ "exec" ],
				"/usr/libexec/ikev2-manager acme-get": [ "exec" ],
				"/usr/libexec/ikev2-manager client-get": [ "exec" ],
				"/usr/libexec/ikev2-manager action-status *": [ "exec" ],
				"/usr/libexec/ikev2-manager advanced-mode inbound": [ "exec" ],
				"/usr/libexec/ikev2-manager advanced-mode outbound": [ "exec" ],
				"/usr/libexec/ikev2-manager advanced-read inbound": [ "exec" ],
				"/usr/libexec/ikev2-manager advanced-read outbound": [ "exec" ],
				"/usr/libexec/ikev2-manager-system get": [ "exec" ],
				"/usr/libexec/ikev2-manager-system dns-get": [ "exec" ],
				"/usr/libexec/ikev2-manager-system doctor": [ "exec" ],
				"/usr/libexec/ikev2-manager-system action-status *": [ "exec" ],
				"/usr/sbin/swanmon list-sas": [ "exec" ]
			}
		},
		"write": {
			"file": {
				"/tmp/ikev2-domains-input-*.domains": [ "write" ],
				"/tmp/ikev2-domains-input-*.cidrs": [ "write" ],
				"/tmp/ikev2-domains-input-*.services": [ "write" ],
				"/var/run/ikev2-manager-user-*.in": [ "write" ],
				"/var/run/ikev2-manager-client-*.in": [ "write" ],
				"/var/run/ikev2-manager-server-*.in": [ "write" ],
				"/var/run/ikev2-manager-profile-*.in": [ "write" ],
				"/usr/libexec/ikev2-manager user-secret-set *": [ "exec" ],
				"/usr/libexec/ikev2-manager client-input *": [ "exec" ],
				"/usr/libexec/ikev2-manager server-input *": [ "exec" ],
				"/usr/libexec/ikev2-manager user-delete *": [ "exec" ],
				"/usr/libexec/ikev2-manager disconnect *": [ "exec" ],
				"/usr/libexec/ikev2-manager disconnect-all": [ "exec" ],
				"/tmp/ikev2-acme-*.in": [ "write" ],
				"/tmp/ikev2-manager-dns-*.in": [ "write" ],
				"/usr/libexec/ikev2-manager acme-set *": [ "exec" ],
				"/usr/libexec/ikev2-manager acme-issue": [ "exec" ],
				"/usr/libexec/ikev2-manager reconnect-client": [ "exec" ],
				"/usr/libexec/ikev2-manager advanced-start inbound *": [ "exec" ],
				"/usr/libexec/ikev2-manager advanced-start outbound *": [ "exec" ],
				"/usr/libexec/ikev2-manager advanced-reset-start inbound": [ "exec" ],
				"/usr/libexec/ikev2-manager advanced-reset-start outbound": [ "exec" ],
				"/usr/libexec/ikev2-manager-system install-deps": [ "exec" ],
				"/usr/libexec/ikev2-manager-system remove-deps": [ "exec" ],
				"/usr/libexec/ikev2-manager-system set-async *": [ "exec" ],
				"/usr/libexec/ikev2-manager-system device-async add-override *": [ "exec" ],
				"/usr/libexec/ikev2-manager-system device-async remove-override *": [ "exec" ],
				"/usr/libexec/ikev2-manager-system dns-set-async *": [ "exec" ],
				"/usr/libexec/ikev2-domains-community schedule *": [ "exec" ],
				"/usr/libexec/ikev2-domain-router activate-async": [ "exec" ],
				"/usr/libexec/ikev2-domain-router deactivate-async": [ "exec" ]
			},
			"ubus": {
				"file": [ "exec", "write" ]
			}
		}
	}
}
